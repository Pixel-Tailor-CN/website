---
import type { AppItem, AccentColor } from '@/config/apps';

interface Props {
  app: AppItem;
}

const { app } = Astro.props;

const accentMap: Record<AccentColor, { ring: string; halo: string; chip: string }> = {
  blue: {
    ring: 'group-hover:border-google-blue/60',
    halo: 'group-hover:shadow-[0_8px_32px_-8px_rgba(66,133,244,0.35)]',
    chip: 'bg-google-blue/10 text-google-blue',
  },
  red: {
    ring: 'group-hover:border-google-red/60',
    halo: 'group-hover:shadow-[0_8px_32px_-8px_rgba(234,67,53,0.35)]',
    chip: 'bg-google-red/10 text-google-red',
  },
  yellow: {
    ring: 'group-hover:border-google-yellow/60',
    halo: 'group-hover:shadow-[0_8px_32px_-8px_rgba(251,188,5,0.35)]',
    chip: 'bg-google-yellow/15 text-[#B5891D] dark:text-google-yellow',
  },
  green: {
    ring: 'group-hover:border-google-green/60',
    halo: 'group-hover:shadow-[0_8px_32px_-8px_rgba(52,168,83,0.35)]',
    chip: 'bg-google-green/10 text-google-green',
  },
};

const accent = accentMap[app.accent];
const hasPlay = !!app.links.googlePlay;
const hasGithub = !!app.links.github;
const hasApk = !!app.links.apk;
---

<article
  class={`group m3-card-hoverable p-6 sm:p-7 flex flex-col gap-5 ${accent.ring} ${accent.halo}`}
  aria-labelledby={`app-${app.id}-title`}
>
  <header class="flex items-start gap-4">
    <div class="shrink-0 w-14 h-14 rounded-(--radius-m3) bg-surface-container-high border border-outline-variant/40 flex items-center justify-center overflow-hidden">
      <img src={app.icon} alt={`${app.name} 图标`} class="w-9 h-9" loading="lazy" />
    </div>
    <div class="flex-1 min-w-0">
      <h3 id={`app-${app.id}-title`} class="text-xl font-semibold text-on-surface">
        {app.name}
      </h3>
      <p class="mt-1 text-sm text-on-surface-variant">
        {app.summary}
      </p>
    </div>
  </header>

  <ul class="flex flex-wrap gap-2">
    {app.highlights.map((h) => (
      <li class={`inline-flex items-center h-7 px-3 rounded-full text-xs font-medium ${accent.chip}`}>
        {h}
      </li>
    ))}
  </ul>

  <div class="mt-auto flex flex-wrap gap-2.5 pt-2">
    {hasPlay && (
      <a
        href={app.links.googlePlay}
        target="_blank"
        rel="noopener noreferrer"
        class="m3-btn-filled h-10 px-5 text-sm"
        aria-label={`在 Google Play 下载 ${app.name}`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true">
          <path d="m13.41 12 7.06-7.06a1.5 1.5 0 0 0-.32-2.39L4.6 1.05a1.2 1.2 0 0 0-.6 0L13.41 12ZM3 2.66v18.68c0 .47.27.9.69 1.1L12.3 13 3 2.66ZM14.78 13.36 5.96 22.94c.21.05.43.06.65 0l15.55-3.5a1.5 1.5 0 0 0 .32-2.39l-3.4-3.4-4.3 1.71Zm6.7-2.94-3.93-1.59L14.18 12l3.37 3.17 3.93-1.6a1.49 1.49 0 0 0 0-2.7Z"/>
        </svg>
        Google Play
      </a>
    )}
    {hasGithub && (
      <a
        href={app.links.github}
        target="_blank"
        rel="noopener noreferrer"
        class="m3-btn-outlined h-10 px-5 text-sm"
        aria-label={`查看 ${app.name} 的 GitHub 仓库`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true">
          <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2c-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.74.08-.73.08-.73 1.21.09 1.85 1.24 1.85 1.24 1.07 1.84 2.81 1.31 3.5 1 .11-.78.42-1.31.76-1.61-2.66-.3-5.46-1.33-5.46-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.81 5.62-5.49 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.82.58A12 12 0 0 0 12 .5Z"/>
        </svg>
        GitHub
      </a>
    )}
    {hasApk && (
      <a
        href={app.links.apk}
        target="_blank"
        rel="noopener noreferrer"
        class="m3-btn-outlined h-10 px-5 text-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        APK
      </a>
    )}
  </div>
</article>
