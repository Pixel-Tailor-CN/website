---
import { site } from '@/config/site';
---

<section
  class="relative overflow-hidden"
  aria-labelledby="hero-title"
>
  <!-- Material You 风格的背景色块（克制、不抢戏） -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-10 overflow-hidden"
  >
    <div class="absolute -top-32 -left-24 w-[420px] h-[420px] rounded-full bg-google-blue/20 blur-3xl"></div>
    <div class="absolute top-12 -right-24 w-[360px] h-[360px] rounded-full bg-google-yellow/20 blur-3xl"></div>
    <div class="absolute -bottom-24 left-1/3 w-[420px] h-[420px] rounded-full bg-google-green/20 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-6xl px-5 sm:px-8 pt-16 sm:pt-24 pb-12 sm:pb-20">
    <!-- 组织 Logo（完整品牌图） -->
    <div class="flex">
      <img
        src={site.logo}
        alt={site.name}
        class="h-20 sm:h-24 w-auto"
        loading="eager"
      />
    </div>

    <h1
      id="hero-title"
      class="mt-8 text-4xl sm:text-6xl font-bold tracking-tight text-on-surface"
    >
      {site.name}
    </h1>

    <p class="mt-4 text-lg sm:text-xl text-on-surface-variant max-w-2xl">
      {site.description}
    </p>

    <p class="mt-2 text-base text-on-surface-variant/80 italic">
      “{site.tagline}”
    </p>

    <!-- 核心理念 chips -->
    <ul class="mt-8 flex flex-wrap gap-2">
      <li class="inline-flex items-center h-9 px-4 rounded-full bg-google-blue/10 text-google-blue text-sm font-medium">
        原生 Android 体验
      </li>
      <li class="inline-flex items-center h-9 px-4 rounded-full bg-google-green/10 text-google-green text-sm font-medium">
        隐私至上
      </li>
      <li class="inline-flex items-center h-9 px-4 rounded-full bg-google-yellow/15 text-[#B5891D] dark:text-google-yellow text-sm font-medium">
        Material You 适配
      </li>
    </ul>

    <div class="mt-10 flex flex-wrap gap-3">
      <a href="#apps" class="m3-btn-filled">
        浏览原点系列
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
          <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
      <a href={site.author.github} target="_blank" rel="noopener noreferrer" class="m3-btn-text">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.699-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48A10.001 10.001 0 0022 12c0-5.523-4.477-10-10-10z"></path>
        </svg>
        GitHub
      </a>
      <a href={site.author.telegram} target="_blank" rel="noopener noreferrer" class="m3-btn-text">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
          <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.896-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"></path>
        </svg>
        Telegram
      </a>
    </div>
  </div>
</section>
